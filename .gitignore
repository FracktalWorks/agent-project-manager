# Secrets — never commit
.env

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
.venv/
venv/
*.egg

# Outputs — keep memory files but skip temp build artefacts
outputs/.tmp/
outputs/morning_report_*.md

# .tmp/ — track utilities + READMEs; ignore cache data and intermediates
.tmp/*
!.tmp/README.md
!.tmp/*.py
!.tmp/search_cache/
.tmp/search_cache/*
!.tmp/search_cache/README.md
!.tmp/web_cache/
.tmp/web_cache/*
!.tmp/web_cache/README.md

# OS
.DS_Store
Thumbs.db

# Sensitive HR data — never commit
data/Employee_Contact*
data/Resumes/

# IDE
.idea/
